# Copy this file to ".env" in the backend repo on the server and fill in real
# values:   cp .env.example .env  &&  nano .env
# docker compose reads it automatically (for ${VAR} substitution in
# docker-compose.yml and as the backend container's environment).

# ---- Application ----
APP_NAME="WOHANA News Platform"
DEBUG=false
# Generate a long random string, e.g. `openssl rand -hex 32`
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- PostgreSQL (the "db" service in docker-compose) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ainews

# ---- Database connection ----
# In Docker the host is the "db" service name (NOT localhost). Use the SAME
# user/password/db as the POSTGRES_* values above. URL-encode special characters
# in the password (e.g. "@" -> "%40").
DATABASE_URL=postgresql+asyncpg://postgres:change_me_strong_password@db:5432/ainews

# ---- Groq (LLM) — get a key at https://console.groq.com ----
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# ---- Scheduler: how often to collect news, in hours (0.25 = 15 minutes) ----
NEWS_FETCH_INTERVAL_HOURS=1

# ---- Admin seed credentials (seeded on every boot by docker-entrypoint.sh) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
